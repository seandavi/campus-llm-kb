@ARTICLE{Badal2023-bt,
  title    = "Guiding principles for the responsible development of artificial
              intelligence tools for healthcare",
  author   = "Badal, Kimberly and Lee, Carmen M and Esserman, Laura J",
  abstract = "Several principles have been proposed to improve use of
              artificial intelligence (AI) in healthcare, but the need for AI
              to improve longstanding healthcare challenges has not been
              sufficiently emphasized. We propose that AI should be designed to
              alleviate health disparities, report clinically meaningful
              outcomes, reduce overdiagnosis and overtreatment, have high
              healthcare value, consider biographical drivers of health, be
              easily tailored to the local population, promote a learning
              healthcare system, and facilitate shared decision-making. These
              principles are illustrated by examples from breast cancer
              research and we provide questions that can be used by AI
              developers when applying each principle to their work.",
  journal  = "Communication \& medicine",
  volume   =  3,
  number   =  1,
  pages    = "47",
  month    =  apr,
  year     =  2023,
  url      = "http://dx.doi.org/10.1038/s43856-023-00279-9",
  file     = "All Papers/B/Badal et al. 2023 - Guiding principles for the responsible development of artificial intelligence tools for healthcare.pdf",
  language = "en",
